  dialogueText: {fileID: 7127021080796935196}
  lines:
  - "\u201CSo you made it\u2026\u201D"
  - "\u201CI was you\u2026 once.\u201D"
  - "\u201COr maybe\u2026 you will be me.\u201D"
  - "\u201CThe thing ahead\u2026 it doesn\u2019t kill you.\u201D"
  - "\u201CIt keeps you.\u201D"
